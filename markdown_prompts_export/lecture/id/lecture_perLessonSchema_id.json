        "Duration": {
          "type": "string",
          "description": "Perkiraan waktu (misalnya '(2-3 menit)')"
        },
        "Materials": {
          "x-format": "{items}",
          "type": "array",
          "items": {
            "x-format": "- {value}",
            "type": "string"
          }
        },
