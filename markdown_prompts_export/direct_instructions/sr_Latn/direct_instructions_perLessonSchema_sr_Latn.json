              "properties": {
                "Question": {
                  "type": "string"
                },
                "ExpectedStudentResponses": {
                  "type": "array",
                  "description": "2-3 očekivana odgovora učenika.",
                  "items": {
                    "type": "string",
                    "x-format": "- {value}"
