        },
        "DirectPresentation": {
          "type": "object",
          "description": "Полный раздел «Прямое изложение». Это ПЕРВАЯ очная активность, и она должна длиться НЕ БОЛЕЕ 10 минут.",
          "properties": {
            "Materials": {
