                          "x-format": "- {value}"
                        },
                        "description": "Alat/kerangka kalimat/visual/pengorganisasi yang konkret untuk tugas ini.",
                        "x-format": "{items}"
                      }
                    },
                    "required": [
                      "StudentName",
                      "PlanProvided",
                      "PlanImplementation"
